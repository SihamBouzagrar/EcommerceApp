@model EcommerceApp.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}
<h1 class="mb-4 text-danger">Delete Product</h1>
<div class="alert alert-warning">
    <strong>Warning:</strong> Are you sure you want to delete this product?
</div>
<div class="card mb-3">
    <div class="card-body">
        <h4 class="card-title">@Model.Name</h4>
        <p class="card-text">
            <strong>Price:</strong> @Model.Price
        </p>
        <p class="card-text">
            <strong>Stock:</strong> @Model.StockQuantity
        </p>
        <p class="card-text">
            <strong>Description:</strong> @Model.Description
        </p>
    </div>
</div>
<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>